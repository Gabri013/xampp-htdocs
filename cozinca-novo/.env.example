APP_NAME="Cozinca ERP (Novo)"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seudominio.com/novo

# ============================================
# MESMO BANCO DE DADOS DO SISTEMA LEGADO PHP
# Não crie um banco novo. Aponte para o mesmo
# schema que o config/database.php legado usa.
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dbcozinca
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# CHAVE SECRETA DA PONTE DE AUTENTICAÇÃO
# Deve ser IDÊNTICA à constante PONTE_SECRET_KEY
# definida no config/config.php do sistema legado.
# Gere uma chave forte com: openssl rand -hex 32
# ============================================
PONTE_SECRET_KEY=

# Domínio raiz para o cookie de sessão compartilhado
# entre o legado (ex: seudominio.com) e o Laravel
# (ex: seudominio.com/novo). Precisa ser o domínio pai.
SESSION_DOMAIN=.seudominio.com
SESSION_DRIVER=file
SESSION_LIFETIME=480

# URL de login do sistema legado, usada como fallback
# quando o usuário não está autenticado em nenhum lado.
LEGADO_LOGIN_URL=https://seudominio.com/modules/auth/login.php

LOG_CHANNEL=stack
LOG_LEVEL=warning

CACHE_STORE=file
QUEUE_CONNECTION=sync