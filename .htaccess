RewriteEngine On

# Forçar HTTPS (descomente em produção)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloquear acesso direto a pastas sensíveis (mas permitir arquivos .php)
Options -Indexes
RedirectMatch 404 ^/(config|vendor|api|uploads)/[^.]*$

# Rotas amigáveis - usar index.php como router
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/(router\.php|index\.php)
RewriteRule ^(.*)$ index.php [L,QSA]